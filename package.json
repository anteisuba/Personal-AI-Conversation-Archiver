{
  "name": "ai-convo-archiver",
  "version": "0.1.0",
  "description": "A local-first CLI tool to import AI conversation logs, refine them into knowledge-oriented notes, and publish them into Obsidian.",
  "type": "module",
  "bin": {
    "ai-archive": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "chatgpt",
    "claude",
    "obsidian",
    "knowledge-base",
    "conversation",
    "archiver",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.7",
    "pathe": "^2.0.3",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
